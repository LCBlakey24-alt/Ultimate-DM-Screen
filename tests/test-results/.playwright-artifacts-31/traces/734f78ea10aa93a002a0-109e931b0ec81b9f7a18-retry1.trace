: transparent; background-clip: text; }\n.ember-bg { position: fixed; inset: 0px; pointer-events: none; z-index: 0; overflow: hidden; background: linear-gradient(rgb(11, 15, 25) 0%, rgb(13, 17, 23) 100%); }\n.ember-bg::before { content: \"\"; position: absolute; inset: 0px; background: radial-gradient(80% 50% at 50% 100%, rgba(6, 182, 212, 0.06) 0%, transparent 50%), radial-gradient(60% 40% at 20% 80%, rgba(139, 92, 246, 0.04) 0%, transparent 40%); }\n@keyframes ambient-glow { \n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n.ember-particles { position: fixed; inset: 0px; pointer-events: none; z-index: 1; overflow: hidden; }\n.ember-particles .ember { position: absolute; border-radius: 50%; animation: auto linear 0s infinite normal none running ember-rise; opacity: 0; }\n.ember-particles .ember.small { width: 2px; height: 2px; background: radial-gradient(circle, var(--ember-gold) 0%, transparent 70%); box-shadow: 0 0 4px var(--ember-gold); }\n.ember-particles .ember.medium { width: 3px; height: 3px; background: radial-gradient(circle, var(--ember-orange) 0%, transparent 70%); box-shadow: 0 0 6px var(--ember-orange); }\n.ember-particles .ember.large { width: 4px; height: 4px; background: radial-gradient(circle, var(--ember-bright) 0%, transparent 70%); box-shadow: 0 0 8px var(--ember-bright); }\n.ember-particles .ember:nth-child(1) { left: 5%; animation-duration: 10s; animation-delay: 0s; }\n.ember-particles .ember:nth-child(2) { left: 10%; animation-duration: 12s; animation-delay: 1s; }\n.ember-particles .ember:nth-child(3) { left: 15%; animation-duration: 8s; animation-delay: 2s; }\n.ember-particles .ember:nth-child(4) { left: 20%; animation-duration: 14s; animation-delay: 0.5s; }\n.ember-particles .ember:nth-child(5) { left: 30%; animation-duration: 11s; animation-delay: 3s; }\n.ember-particles .ember:nth-child(6) { left: 40%; animation-duration: 9s; animation-delay: 1.5s; }\n.ember-particles .ember:nth-child(7) { left: 50%; animation-duration: 13s; animation-delay: 2.5s; }\n.ember-particles .ember:nth-child(8) { left: 60%; animation-duration: 10s; animation-delay: 0.8s; }\n.ember-particles .ember:nth-child(9) { left: 70%; animation-duration: 12s; animation-delay: 1.8s; }\n.ember-particles .ember:nth-child(10) { left: 80%; animation-duration: 8s; animation-delay: 3.5s; }\n.ember-particles .ember:nth-child(11) { left: 85%; animation-duration: 15s; animation-delay: 0.3s; }\n.ember-particles .ember:nth-child(12) { left: 90%; animation-duration: 11s; animation-delay: 2.2s; }\n.ember-particles .ember:nth-child(13) { left: 95%; animation-duration: 9s; animation-delay: 1.2s; }\n.ember-particles .ember:nth-child(14) { left: 25%; animation-duration: 14s; animation-delay: 4s; }\n.ember-particles .ember:nth-child(15) { left: 75%; animation-duration: 10s; animation-delay: 2.8s; }\n@keyframes ember-rise { \n  0% { bottom: -10px; opacity: 0; transform: translateX(0px) scale(0.5); }\n  5% { opacity: 0.8; }\n  30% { opacity: 0.9; transform: translateX(15px) scale(1); }\n  60% { opacity: 0.6; transform: translateX(-10px) scale(0.9); }\n  90% { opacity: 0.2; }\n  100% { bottom: 100%; opacity: 0; transform: translateX(5px) scale(0.3); }\n}\n.smokey-bg { position: fixed; inset: 0px; pointer-events: none; z-index: 0; background: var(--background); }\n.card-hover-gm { transition: 0.3s; cursor: pointer; }\n.card-hover-gm:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4),\n    0 0 20px var(--gm-glow),\n    inset 0 1px 0 rgba(245, 158, 11, 0.1); border-color: var(--gm-primary) !important; }\n.card-hover-player { transition: 0.3s; cursor: pointer; }\n.card-hover-player:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4),\n    0 0 20px var(--player-glow),\n    inset 0 1px 0 rgba(6, 182, 212, 0.1); border-color: var(--player-primary) !important; }\n.card-hover { transition: 0.3s; }\n.card-hover:hover { transform: translateY(-2px); box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 30px; }\n.text-gm { color: var(--gm-primary); }\n.text-player { color: var(--player-primary); }\n.bg-gm { background-color: var(--gm-primary); }\n.bg-player { background-color: var(--player-primary); }\n.border-gm { border-color: var(--gm-primary); }\n.border-player { border-color: var(--player-primary); }\n.glow-gm { box-shadow: 0 0 20px var(--gm-glow); }\n.glow-player { box-shadow: 0 0 20px var(--player-glow); }\n.card-base { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); }\n.btn-gm { background: linear-gradient(135deg, var(--gm-primary) 0%, var(--gm-secondary) 100%); color: rgb(11, 15, 25); border: none; font-weight: 600; box-shadow: 0 4px 15px var(--gm-glow); transition: 0.2s; }\n.btn-gm:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 6px 20px var(--gm-glow); }\n.btn-player { background: linear-gradient(135deg, var(--player-primary) 0%, var(--player-secondary) 100%); color: rgb(11, 15, 25); border: none; font-weight: 600; box-shadow: 0 4px 15px var(--player-glow); transition: 0.2s; }\n.btn-player:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 6px 20px var(--player-glow); }\n.btn-secondary { background: var(--surface-highlight); color: var(--text-primary); border: 1px solid var(--border); transition: 0.2s; }\n.btn-secondary:hover { border-color: var(--gm-primary); background: var(--surface); }\n@keyframes float { \n  0%, 100% { transform: translateY(0px); }\n  50% { transform: translateY(-8px); }\n}\n@keyframes pulse-glow { \n  0%, 100% { opacity: 0.5; }\n  50% { opacity: 0.8; }\n}\n@keyframes shimmer { \n  0% { background-position: -200% center; }\n  100% { background-position: 200% center; }\n}\n.animate-float { animation: 3s ease-in-out 0s infinite normal none running float; }\n.animate-pulse-glow { animation: 2s ease-in-out 0s infinite normal none running pulse-glow; }\n.animate-shimmer { animation: 3s ease-in-out 0s infinite normal none running shimme