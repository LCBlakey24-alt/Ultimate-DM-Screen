ore, .smokey-bg::after { content: \"\"; position: absolute; width: 200%; height: 200%; top: -50%; left: -50%; background: radial-gradient(rgba(122, 31, 31, 0.15) 0%, transparent 50%), radial-gradient(at 20% 80%, rgba(197, 75, 44, 0.1) 0%, transparent 40%), radial-gradient(at 80% 20%, rgba(242, 165, 65, 0.08) 0%, transparent 40%); animation: 30s ease-in-out 0s infinite normal none running smokeFloat; }\n.smokey-bg::after { background: radial-gradient(at 70% 70%, rgba(43, 15, 15, 0.2) 0%, transparent 50%), radial-gradient(at 30% 30%, rgba(45, 42, 58, 0.15) 0%, transparent 45%); animation: 40s ease-in-out 0s infinite reverse none running smokeFloat; }\n@keyframes smokeFloat { \n  0%, 100% { transform: translate(0px, 0px) rotate(0deg) scale(1); opacity: 0.6; }\n  25% { transform: translate(2%, -2%) rotate(5deg) scale(1.05); opacity: 0.8; }\n  50% { transform: translate(-1%, 1%) rotate(-3deg) scale(0.98); opacity: 0.5; }\n  75% { transform: translate(1%, 2%) rotate(2deg) scale(1.02); opacity: 0.7; }\n}\n@keyframes borderLightTrace { \n  0% { background-position: 0% 0%; }\n  25% { background-position: 100% 0%; }\n  50% { background-position: 100% 100%; }\n  75% { background-position: 0% 100%; }\n  100% { background-position: 0% 0%; }\n}\n@keyframes borderLightSpin { \n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n.tron-border-blue { position: relative; overflow: hidden; }\n.tron-border-blue::before { content: \"\"; position: absolute; inset: -2px; background: linear-gradient(90deg, transparent 0%, transparent 40%, rgb(6, 182, 212) 45%, rgb(255, 255, 255) 50%, rgb(6, 182, 212) 55%, transparent 60%, transparent 100%) 0% 0% / 200% 200%; animation: 3s linear 0s infinite normal none running borderLightTrace; z-index: -1; }\n.tron-border-blue::after { content: \"\"; position: absolute; inset: 1px; background: var(--bg-panel, #1A1A1A); z-index: -1; }\n.tron-border-red { position: relative; overflow: hidden; }\n.tron-border-red::before { content: \"\"; position: absolute; inset: -2px; background: linear-gradient(90deg, transparent 0%, transparent 40%, rgb(225, 29, 72) 45%, rgb(255, 255, 255) 50%, rgb(225, 29, 72) 55%, transparent 60%, transparent 100%) 0% 0% / 200% 200%; animation: 3s linear 0s infinite normal none running borderLightTrace; z-index: -1; }\n.tron-border-red::after { content: \"\"; position: absolute; inset: 1px; background: var(--bg-panel, #1A1A1A); z-index: -1; }\n.tron-border-spin-blue { position: relative; z-index: 0; }\n.tron-border-spin-blue::before { content: \"\"; position: absolute; inset: -2px; background: conic-gradient(transparent 0deg, transparent 60deg, rgb(6, 182, 212) 80deg, rgb(34, 211, 238) 90deg, rgb(255, 255, 255) 95deg, rgb(34, 211, 238) 100deg, rgb(6, 182, 212) 110deg, transparent 130deg, transparent 360deg); animation: 2s linear 0s infinite normal none running borderLightSpin; z-index: -2; }\n.tron-border-spin-blue::after { content: \"\"; position: absolute; inset: 1px; background: var(--bg-panel, #1A1A1A); z-index: -1; }\n.tron-border-spin-red { position: relative; z-index: 0; }\n.tron-border-spin-red::before { content: \"\"; position: absolute; inset: -2px; background: conic-gradient(transparent 0deg, transparent 60deg, rgb(225, 29, 72) 80deg, rgb(244, 63, 94) 90deg, rgb(255, 255, 255) 95deg, rgb(244, 63, 94) 100deg, rgb(225, 29, 72) 110deg, transparent 130deg, transparent 360deg); animation: 2s linear 0s infinite normal none running borderLightSpin; z-index: -2; }\n.tron-border-spin-red::after { content: \"\"; position: absolute; inset: 1px; background: var(--bg-panel, #1A1A1A); z-index: -1; }\n.tron-border-spin-dual { position: relative; z-index: 0; }\n.tron-border-spin-dual::before { content: \"\"; position: absolute; inset: -2px; background: conic-gradient(transparent 0deg, transparent 30deg, rgb(6, 182, 212) 50deg, rgb(255, 255, 255) 60deg, rgb(6, 182, 212) 70deg, transparent 90deg, transparent 180deg, transparent 210deg, rgb(225, 29, 72) 230deg, rgb(255, 255, 255) 240deg, rgb(225, 29, 72) 250deg, transparent 270deg, transparent 360deg); animation: 2.5s linear 0s infinite normal none running borderLightSpin; z-index: -2; }\n.tron-border-spin-dual::after { content: \"\"; position: absolute; inset: 1px; background: var(--bg-panel, #1A1A1A); z-index: -1; }\n.tron-border-spin-fast::before { animation-duration: 1.2s !important; }\n.tron-border-spin-slow::before { animation-duration: 4s !important; }\n:root { --bg-black: #0D0D0D; --bg-dark: #141414; --bg-panel: #1A1A1A; --bg-card: #1F1F1F; --bg-hover: #2A2A2A; --bg-elevated: #333333; --bg-light: #404040; --accent-red: #E11D48; --accent-red-hover: #F43F5E; --accent-red-subtle: rgba(225, 29, 72, 0.15); --accent-red-border: rgba(225, 29, 72, 0.4); --text-primary: #FFFFFF; --text-secondary: #B3B3B3; --text-muted: #808080; --text-dim: #666666; --success: #22C55E; --warning: #F59E0B; --danger: #EF4444; --border-dark: rgba(255, 255, 255, 0.06); --border-default: rgba(255, 255, 255, 0.1); --border-hover: rgba(255, 255, 255, 0.15); --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.5); --shadow-md: 0 4px 8px rgba(0, 0, 0, 0.6); --shadow-lg: 0 8px 16px rgba(0, 0, 0, 0.7); --radius-none: 0px; --radius-sm: 0px; --radius-md: 0px; --radius-lg: 0px; --radius-xl: 0px; }\n* { margin: 0px; padding: 0px; box-sizing: border-box; }\nbody { font-family: Montserrat, -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg-black); color: var(--text-primary); min-height: 100vh; -webkit-font-smoothing: antialiased; }\n.brand-font, .logo-title, h1.brand, h2.brand { font-family: Montserrat, sans-serif; font-weight: 600; }\n.App { min-height: 100vh; background: var(--bg-black); }\n.loading-screen { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: var(--bg-black); }\n.loading-spinner { width: 48px; height: 48px; border-right-color: ; border-right-style: ; border-right-width: ; border-bottom-color: ; border-bottom-style: ; border-bottom-width: ; border-left-color: ; border-left-style: ; border-left-width: ; border-image-source: ; border-image-slice: ; border-image-width: ; border-image-outset: ; border-image-repeat: ; border-top: 3px solid var(--accent-red); border-radius: 50%; animation: 0.8s linear 0s infinite normal none running spin; }\n@keyframes spin { \n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n@keyframes fade-in { \n  0% { opacity: 0; transform: translateY(10px); }\n  100% { opacity: 1; transform: translateY(0px); }\n}\n@keyframes float { \n  0%, 100% { transform: translateY(0px); }\n  50% { transform: translateY(-6px); }\n}\n@keyframes slide-in-right { \n  0% { width: 0px; }\n  100% { width: 3px; }\n}\n@keyframes tab-activate { \n  0% { background: var(--bg-hover); }\n  50% { background: var(--accent-red-subtle); }\n  100% { background: var(--accent-red); }\n}\n.animate-float { animation: 3s ease-in-out 0s infinite normal none running float; }\nh1, h2, h3, h4, h5, h6 { font-family: Montserrat, sans-serif; font-weight: 600; color: var(--text-primary); }\np, span, div, label, a, button { font-family: Montserrat, sans-serif; }\n.glow-panel { background: var(--bg-panel); border: 1px solid var(--border-default); padding: 24px; transition: 0.2s; }\n.glow-panel:hover { border-color: var(--border-hover); }\n.card, .glow-card { background: var(--bg-card); border: 1px solid var(--border-default); padding: 20px; transition: 0.2s; }\n.card:hover, .glow-card:hover { background: var(--bg-hover); border-color: var(--border-hover); }\n.input-glow, .input, input[type=\"text\"], input[type=\"email\"], input[type=\"password\"], input[type=\"number\"], input[type=\"search\"] { background: var(--bg-dark); border: 1px solid var(--border-default); color: var(--text-primary); padding: 12px 16px; width: 100%; font-size: 14px; font-family: Montserrat, sans-serif; transition: 0.2s; }\n.input-glow:focus, .input:focus, input:focus { outline: none; border-color: var(--accent-red); box-shadow: 0 0 0 2px var(--accent-red-subtle); }\n.input-glow::placeholder, .input::placeholder, input::placeholder { color: var(--text-muted); }\n.textarea-glow, .textarea, textarea { background: var(--bg-dark); border: 1px solid var(--border-default); color: var(--text-primary); padding: 14px 16px; width: 100%; min-height: 100px; resize: vertical; font-family: Montserrat, sans-serif; font-size: 14px; transition: 0.2s; line-height: 1.6; }\n.textarea-glow:focus, .textarea:focus, textarea:focus { outline: none; border-color: var(--accent-red); box-shadow: 0 0 0 2px var(--accent-red-subtle); }\n.btn-primary { background: var(--accent-red); color: var(--text-primary); border: none; padding: 12px 24px; font-weight: 600; font-size: 14px; font-family: Montserrat, sans-serif; cursor: pointer; transition: 0.15s; text-transform: uppercase; letter-spacing: 0.5px; }\n.btn-primary:hover { background: var(--accent-red-hover); }\n.btn-primary:active { transform: scale(0.98); }\n.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }\n.btn-secondary { background: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border-default); padding: 12px 24px; font-weight: 600; font-size: 14px; font-family: Montserrat, sans-serif; cursor: pointer; transition: 0.15s; }\n.btn-secondary:hover { background: var(--bg-hover); border-color: var(--border-hover); }\n.btn-secondary:active { transform: scale(0.98); }\n.btn-outline { background: transparent; color: var(--text-secondary); border: 1px solid var(--border-default); padding: 10px 20px; font-weight: 600; font-size: 13px; font-family: Montserrat, sans-serif; cursor: pointer; transition: 0.2s; }\n.btn-outline:hover { border-color: var(--accent-red); color: var(--accent-red); background: var(--accent-red-subtle); }\n.btn-danger { background: rgba(239, 68, 68, 0.1); color: var(--danger); border: 1px solid rgba(239, 68, 68, 0.3); padding: 10px 16px; font-weight: 600; font-size: 13px; font-family: Montserrat, sans-serif; cursor: pointer; transition: 0.2s; }\n.btn-danger:hover { background: rgba(239, 68, 68, 0.2); border-color: var(--danger); }\n.btn-icon { background: var(--bg-card); border: 1px solid var(--border-default); color: var(--text-secondary); padding: 10px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; }\n.btn-icon:hover { background: var(--bg-hover); border-color: var(--accent-red); color: var(--accent-red); }\n.sidebar-tab-nav { display: flex; flex-direction: column; gap: 2px; padding: 8px 0px; background: var(--bg-dark); }\n.sidebar-tab-item { position: relative; display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: transparent; border: none; color: var(--text-secondary); font-size: 14px; font-family: Montserrat, sans-serif; font-weight: 500; cursor: pointer; transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1); text-align: left; width: 100%; overflow: hidden; }\n.sidebar-tab-item::after { content: \"\"; position: absolute; right: 0px; top: 0px; bottom: 0px; width: 0px; background: var(--accent-red); transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1); }\n.sidebar-tab-item:hover { background: var(--bg-hover); color: var(--text-primary); }\n.sidebar-tab-item:hover::after { width: 3px; }\n.sidebar-tab-item.active { background: var(--accent-red); color: var(--text-primary); animation: 0.3s ease 0s 1 normal none running tab-activate; }\n.sidebar-tab-item.active::after { display: none; }\n.tab-nav { display: flex; gap: 2px; padding: 4px; background: var(--bg-dark); border: 1px solid var(--border-default); flex-wrap: wrap; }\n.tab-item { position: relative; padding: 10px 18px; background: transparent; border: none; color: var(--text-secondary); font-weight: 500; font-size: 13px; font-family: Montserrat, sans-serif; cursor: pointer; transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1); display: flex; align-items: center; gap: 8px; overflow: hidden; }\n.tab-item::after { content: \"\"; position: absolute; right: 0px; top: 0px; bottom: 0px; width: 0px; background: var(--accent-red); transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1); }\n.tab-item:hover { background: var(--bg-hover); color: var(--text-primary); }\n.tab-item:hover::after { width: 3px; }\n.tab-item.active { background: var(--accent-red); color: var(--text-primary); }\n.tab-item.active::after { display: none; }\nselect, select.input-glow { background-size: ; background-attachment: ; background-origin: ; background-clip: ; background-color: ; border: 1px solid var(--border-default); color: var(--text-primary); padding: 12px 40px 12px 16px; font-size: 14px; cursor: pointer; appearance: none; background-image: url(\"data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2720%27 height=%2720%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27%23E11D48%27 stroke-width=%272%27%3E%3Cpath d=%27M6 9l6 6 6-6%27/%3E%3C/svg%3E\"); background-repeat: no-repeat; background-position: right 12px center; transition: 0.2s; }\nselect:focus { outline: none; border-color: var(--accent-red); box-shadow: 0 0 0 2px var(--accent-red-subtle); }\nselect option { background: var(--bg-panel); color: var(--text-primary); }\n.item-box { background: var(--bg-card); border: 1px solid var(--border-default); padding: 12px 16px; color: var(--text-primary); font-size: 13px; cursor: pointer; transition: 0.2s; }\n.item-box:hover { background: var(--bg-hover); border-color: var(--accent-red); }\n.item-box.selected { background: var(--accent-red-subtle); border-color: var(--accent-red); }\n.item-box.add { border-style: dashed; color: var(--text-muted); background: transparent; }\n.item-box.add:hover { border-color: var(--accent-red); color: var(--accent-red); }\n.stat-block { display: flex; flex-direction: column; align-items: center; padding: 12px 16px; background: var(--bg-card); border: 1px solid var(--border-default); min-width: 70px; }\n.stat-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; font-weight: 600; }\n.stat-value { font-size: 18px; font-weight: 400; color: var(--text-primary); }\n.hp-bar { width: 100%; height: 8px; background: var(--bg-dark); overflow: hidden; }\n.hp-bar-fill { height: 100%; background: var(--success); transition: width 0.3s; }\n.initiative-entry { padding: 14px; background: var(--bg-card); border: 1px solid var(--border-default); margin-bottom: 8px; transition: 0.2s; }\n.initiative-entry:hover { background: var(--bg-hover); }\n.initiative-entry.active { border-top-color: ; border-right-color: ; border-bottom-color: ; border-left: 3px solid var(--accent-red); }\n.modal { background: var(--bg-panel); border: 1px solid var(--border-default); padding: 28px; max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto; }\n.note-item { background: var(--bg-card); border: 1px solid var(--border-default); padding: 14px; margin-bottom: 10px; }\n.note-time { font-size: 11px; color: var(--text-muted); margin-bottom: 6px; font-weight: 600; }\n.note-content { color: var(--text-secondary); font-size: 13px; line-height: 1.6; }\n.system-badge { font-size: 11px; color: var(--accent-red); background: var(--accent-red-subtle); padding: 5px 12px; border: 1px solid var(--accent-red-border); font-weight: 600; }\n::-webkit-scrollbar { width: 8px; height: 8px; }\n::-webkit-scrollbar-track { background: var(--bg-dark); }\n::-webkit-scrollbar-thumb { background: var(--bg-elevated); }\n::-webkit-scrollbar-thumb:hover { background: var(--accent-red); }\n.text-red { color: var(--accent-red); }\n.text-white { color: var(--text-primary); }\n.text-muted { color: var(--text-muted); }\n.clickable-box { cursor: pointer; transition: 0.2s; }\n.clickable-box:hover { background: var(--bg-hover); }\n.animate-spin, .spin { animation: 1s linear 0s infinite normal none running spin; }\n.progress-bar { width: 100%; height: 6px; background: var(--bg-card); overflow: hidden; }\n.progress-bar-fill { height: 100%; background: var(--accent-red); transition: width 0