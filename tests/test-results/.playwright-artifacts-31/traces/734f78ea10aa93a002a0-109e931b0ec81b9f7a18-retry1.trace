.input-glow { background-size: ; background-attachment: ; background-origin: ; background-clip: ; background-color: ; border: 1px solid var(--border-default); color: var(--text-primary); padding: 12px 40px 12px 16px; font-size: 14px; cursor: pointer; appearance: none; background-image: url(\"data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2720%27 height=%2720%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27%23E11D48%27 stroke-width=%272%27%3E%3Cpath d=%27M6 9l6 6 6-6%27/%3E%3C/svg%3E\"); background-repeat: no-repeat; background-position: right 12px center; transition: 0.2s; }\nselect:focus { outline: none; border-color: var(--accent-red); box-shadow: 0 0 0 2px var(--accent-red-subtle); }\nselect option { background: var(--bg-panel); color: var(--text-primary); }\n.item-box { background: var(--bg-card); border: 1px solid var(--border-default); padding: 12px 16px; color: var(--text-primary); font-size: 13px; cursor: pointer; transition: 0.2s; }\n.item-box:hover { background: var(--bg-hover); border-color: var(--accent-red); }\n.item-box.selected { background: var(--accent-red-subtle); border-color: var(--accent-red); }\n.item-box.add { border-style: dashed; color: var(--text-muted); background: transparent; }\n.item-box.add:hover { border-color: var(--accent-red); color: var(--accent-red); }\n.stat-block { display: flex; flex-direction: column; align-items: center; padding: 12px 16px; background: var(--bg-card); border: 1px solid var(--border-default); min-width: 70px; }\n.stat-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; font-weight: 600; }\n.stat-value { font-size: 18px; font-weight: 400; color: var(--text-primary); }\n.hp-bar { width: 100%; height: 8px; background: var(--bg-dark); overflow: hidden; }\n.hp-bar-fill { height: 100%; background: var(--success); transition: width 0.3s; }\n.initiative-entry { padding: 14px; background: var(--bg-card); border: 1px solid 